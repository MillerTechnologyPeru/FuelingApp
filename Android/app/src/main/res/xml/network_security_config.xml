<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext HTTP is blocked by default since API 28. Only local
         development hosts get an exception here: FUELING_SERVER_URL
         defaults to http://localhost:8080, and 10.0.2.2 is the Android
         emulator's alias for the host machine's own localhost. A real
         deployment should use HTTPS, which needs no exception. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
